# Backend
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
# Supabase/Postgres example: postgresql+asyncpg://user:password@host:6543/postgres
SECRET_KEY=generate-a-fernet-key-with-python-cryptography
CORS_ORIGINS=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama (usato solo se AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# AI Provider — ollama | groq | gemini
# Groq: gratis, OpenAI-compatible. Registrati su console.groq.com per l'API key.
# Gemini: gratis (tier generoso). API key da aistudio.google.com
AI_PROVIDER=ollama
AI_API_KEY=
# Lascia vuoto per usare il modello default del provider (Groq: llama-3.3-70b-versatile, Gemini: gemini-2.0-flash)
AI_MODEL=
# Lascia vuoto per usare l'endpoint default del provider (solo per Groq/provider OpenAI-compatible)
AI_BASE_URL=
# Override system prompt. Lascia vuoto per usare il default ottimizzato.
AI_SYSTEM_PROMPT=
# Temperatura sampling. Più bassa = messaggi più consistenti. Consigliato: 0.35
AI_TEMPERATURE=0.35

# Timing defaults
MIN_DELAY_SECONDS=120
MAX_DELAY_SECONDS=480
SESSION_MIN_MESSAGES=10
SESSION_MAX_MESSAGES=20
SESSION_BREAK_MIN_MINUTES=30
SESSION_BREAK_MAX_MINUTES=60
ACTIVE_HOURS_START=8
ACTIVE_HOURS_END=23

# Account defaults
DEFAULT_DAILY_LIMIT=20
# Cap anti-ban: lookup user_info/giorno per account durante lo scraping (override per-campagna)
SCRAPE_DAILY_LIMIT=180
WARMUP_ENABLED=true
MAX_CONCURRENT_BROWSERS=3

# Warm-up curve — DM/giorno per warmup_day. Formato "giorno_inizio-giorno_fine:limite,..."
# Range inclusivi. warmup_day=0 = warm-up finito (usa limite campagna).
# Default: giorni 1-3 → 5 DM, giorni 4-7 → 12 DM, giorni 8-14 → 20 DM.
WARMUP_LIMITS=1-3:5,4-7:12,8-14:20

# Cap hard per età account (giorni dalla creazione riga DB). Formato "soglia:limite,..."
# Cumulativo: vince ultima soglia raggiunta. "none" = nessun cap.
# Bypassato se account ha già inviato >= PROVEN_ACCOUNT_THRESHOLD messaggi totali.
# Default: giorni 0-2 → 0 DM (solo browsing), 3-6 → 3 DM, 7-13 → 8 DM, 14+ → nessun cap.
AGE_BASED_CAPS=0:0,3:3,7:8,14:none

# Soglia messaggi totali oltre la quale l'account è "rodato" → cap età disattivato.
# Protegge account IG vecchi aggiunti di recente al bot.
PROVEN_ACCOUNT_THRESHOLD=30

# Browser
BROWSER_PROFILES_DIR=./data/browser_profiles
HEADLESS=true

# JWT auth (multi-user). Lascia VUOTO per disabilitare auth (modalità single-user legacy).
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
# Durata token in minuti. Default: 7 giorni.
JWT_EXPIRES_MINUTES=10080

# Telegram notifications (opzionale). Entrambi i campi devono essere settati per attivare.
# Token bot: parla con @BotFather su Telegram. chat_id: parla con @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_COMMANDS_ENABLED=true
TELEGRAM_POLL_TIMEOUT_SECONDS=5
TELEGRAM_SESSION_RECAP_ENABLED=true

# Auth login rate limit
AUTH_LOGIN_RATE_LIMIT_ATTEMPTS=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_TRUST_FORWARDED_FOR=false

# Anomaly detector — auto-pausa campagne/account su pattern critici.
ANOMALY_AUTO_STOP_ENABLED=true
ANOMALY_BAN_THRESHOLD_PER_HOUR=3
ANOMALY_CONSECUTIVE_DM_FAILURES=5
ANOMALY_CHALLENGE_THRESHOLD_PER_DAY=3
ANOMALY_WORKER_CRASH_THRESHOLD_PER_HOUR=3
